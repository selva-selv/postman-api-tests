      "name": "Profile",
      "item": [
        {
          "name": "Update Profile Data",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// ==============================================================",
                  "// E2E QA SCRIPT -- CREATE USER API (TC_001 to TC_055)",
                  "// ==============================================================",
                  "// Safe parse response",
                  "var res = {};",
                  "try {",
                  "    res = pm.response.json();",
                  "} catch (e) {",
                  "    console.log(\"Invalid JSON response\");",
                  "}",
                  "var responseText = JSON.stringify(res).toLowerCase();",
                  "var statusCode = pm.response.code;",
                  "// Safe parse request",
                  "var req = {};",
                  "try {",
                  "    req = JSON.parse(pm.request.body.raw || \"{}\");",
                  "} catch (e) {",
                  "    console.log(\"Could not parse request body\");",
                  "}",
                  "// TC_001 -- SUCCESS: Send full valid payload, expect 201",
                  "pm.test(\"TC_001 - User created successfully with 201 status\", function () {",
                  "    if (statusCode === 200 || statusCode === 201) {",
                  "        pm.expect(statusCode).to.be.oneOf([200, 201]);",
                  "        pm.expect(responseText).to.include(\"success\");",
                  "        pm.expect(res).to.have.property(\"data\");",
                  "    }",
                  "});",
                  "// TC_002 -- NAME: Empty fullName",
                  "pm.test(\"TC_002 - Empty fullName - Full name is required should display\", function () {",
                  "    if (req.fullName === \"\" || req.fullName === null) {",
                  "        pm.expect(statusCode).to.equal(400);",
                  "        pm.expect(responseText).to.satisfy(function (t) {",
                  "            return t.includes(\"full name is required\") || (t.includes(\"name\") && t.includes(\"required\"));",
                  "        });",
                  "    }",
                  "});",
                  "// TC_003 -- NAME: Duplicate fullName",
                  "pm.test(\"TC_003 - Duplicate fullName - Name already exists should display\", function () {",
                  "    if (statusCode === 409 && responseText.includes(\"name\")) {",
                  "        pm.expect(responseText).to.satisfy(function (t) {",
                  "            return t.includes(\"already exists\") || t.includes(\"already\");",
                  "        });",
                  "    }",
                  "});",
                  "// TC_004 -- NAME: Special characters",
                  "pm.test(\"TC_004 - Special characters in name - alphabets-only message should display\", function () {",
                  "    if (req.fullName && /[^a-zA-Z\\s]/.test(req.fullName)) {",
                  "        pm.expect(statusCode).to.equal(400);",
                  "        pm.expect(responseText).to.satisfy(function (t) {",
                  "            return t.includes(\"alphabets\") || t.includes(\"only alphabets\") || t.includes(\"invalid\");",
                  "        });",
                  "    }",
                  "});",
                  "// TC_005 -- NAME: Numbers in name",
                  "pm.test(\"TC_005 - Numbers in name - alphabets-only message should display\", function () {",
                  "    if (req.fullName && /\\d/.test(req.fullName)) {",
                  "        pm.expect(statusCode).to.equal(400);",
                  "        pm.expect(responseText).to.satisfy(function (t) {",
                  "            return t.includes(\"alphabets\") || t.includes(\"only alphabets\") || t.includes(\"invalid\");",
                  "        });",
                  "    }",
                  "});",
                  "// TC_006 -- NAME: Only spaces",
                  "pm.test(\"TC_006 - Only spaces in name - Full name cannot be empty should display\", function () {",
                  "    if (req.fullName && req.fullName.trim() === \"\" && req.fullName.length > 0) {",
                  "        pm.expect(statusCode).to.equal(400);",
                  "        pm.expect(responseText).to.satisfy(function (t) {",
                  "            return t.includes(\"cannot be empty\") || t.includes(\"required\") || t.includes(\"blank\");",
                  "        });",
                  "    }",
                  "});",
                  "// TC_007 -- NAME: Leading/trailing spaces",
                  "pm.test(\"TC_007 - Leading or trailing spaces in name - should trim or show validation\", function () {",
                  "    if (req.fullName && req.fullName !== req.fullName.trim()) {",
                  "        var passed = (statusCode === 200 || statusCode === 201) ||",
                  "            (statusCode === 400 && responseText.includes(\"name\"));",
                  "        pm.expect(passed).to.be.true;",
                  "    }",
                  "});",
                  "// TC_008 -- NAME: Very long name",
                  "pm.test(\"TC_008 - Very long name - too long or validation message should display\", function () {",
                  "    if (req.fullName && req.fullName.length > 100) {",
                  "        pm.expect(statusCode).to.equal(400);",
                  "        pm.expect(responseText).to.satisfy(function (t) {",
                  "            return t.includes(\"too long\") || t.includes(\"maximum\") || t.includes(\"name\");",
                  "        });",
                  "    }",
                  "});",
                  "// TC_009 -- EMAIL: Empty email",
                  "pm.test(\"TC_009 - Empty email - Email is required should display\", function () {",
                  "    if (req.email === \"\" || req.email === null) {",
                  "        pm.expect(statusCode).to.equal(400);",
                  "        pm.expect(responseText).to.satisfy(function (t) {",
                  "            return t.includes(\"email\") && t.includes(\"required\");",
                  "        });",
                  "    }",
                  "});",
                  "// TC_010 -- EMAIL: Invalid format",
                  "pm.test(\"TC_010 - Invalid email format - Invalid email format should display\", function () {",
                  "    if (req.email && !/^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$/.test(req.email)) {",
                  "        pm.expect(statusCode).to.equal(400);",
                  "        pm.expect(responseText).to.satisfy(function (t) {",
                  "            return t.includes(\"invalid email\") || (t.includes(\"invalid\") && t.includes(\"email\"));",
                  "        });",
                  "    }",
                  "});",
                  "// TC_011 -- EMAIL: Duplicate",
                  "pm.test(\"TC_011 - Duplicate email - Email already exists should display\", function () {",
                  "    if (statusCode === 409 && responseText.includes(\"email\")) {",
                  "        pm.expect(responseText).to.satisfy(function (t) {",
                  "            return t.includes(\"already exists\") || t.includes(\"already\");",
                  "        });",
                  "    }",
                  "});",
                  "// TC_012 -- EMAIL: Fake domain",
                  "pm.test(\"TC_012 - Fake email domain - Invalid email domain should display\", function () {",
                  "    if (req.email && req.email.includes(\"@fake\")) {",
                  "        pm.expect(statusCode).to.equal(400);",
                  "        pm.expect(responseText).to.satisfy(function (t) {",
                  "            return t.includes(\"domain\") || t.includes(\"invalid email\") || t.includes(\"invalid\");",
                  "        });",
                  "    }",
                  "});",
                  "// TC_013 -- EMAIL: Special characters",
                  "pm.test(\"TC_013 - Special characters in email - Invalid email format should display\", function () {",
                  "    if (req.email && /[#$%]/.test(req.email)) {",
                  "        pm.expect(statusCode).to.equal(400);",
                  "        pm.expect(responseText).to.satisfy(function (t) {",
                  "            return t.includes(\"invalid email\") || (t.includes(\"invalid\") && t.includes(\"email\"));",
                  "        });",
                  "    }",
                  "});",
                  "// TC_014 -- EMAIL: Uppercase",
                  "pm.test(\"TC_014 - Uppercase email - should accept or normalize\", function () {",
                  "    if (req.email && req.email === req.email.toUpperCase() && req.email.includes(\"@\")) {",
                  "        var passed = statusCode === 200 || statusCode === 201 ||",
                  "            (statusCode === 400 && responseText.includes(\"email\"));",
                  "        pm.expect(passed).to.be.true;",
                  "    }",
                  "});",
                  "// TC_015 -- EMAIL: Whitespace",
                  "pm.test(\"TC_015 - Whitespace email - should trim and validate properly\", function () {",
                  "    if (req.email && req.email !== req.email.trim()) {",
                  "        var passed = (statusCode === 200 || statusCode === 201) ||",
                  "            (statusCode === 400 && responseText.includes(\"email\"));",
                  "        pm.expect(passed).to.be.true;",
                  "    }",
                  "});",
                  "// TC_016 -- PHONE: Empty",
                  "pm.test(\"TC_016 - Empty phone number - Phone number is required should display\", function () {",
                  "    if (req.phoneNumber === \"\" || req.phoneNumber === null) {",
                  "        pm.expect(statusCode).to.equal(400);",
                  "        pm.expect(responseText).to.satisfy(function (t) {",
                  "            return t.includes(\"phone\") && t.includes(\"required\");",
                  "        });",
                  "    }",
                  "});",
                  "// TC_017 -- PHONE: Invalid length",
                  "pm.test(\"TC_017 - Invalid phone length - Invalid phone number should display\", function () {",
                  "    if (req.phoneNumber && /^\\d{1,4}$/.test(req.phoneNumber)) {",
                  "        pm.expect(statusCode).to.equal(400);",
                  "        pm.expect(responseText).to.satisfy(function (t) {",
                  "            return t.includes(\"invalid phone\") || (t.includes(\"phone\") && t.includes(\"invalid\"));",
                  "        });",
                  "    }",
                  "});",
                  "// TC_018 -- PHONE: Duplicate",
                  "pm.test(\"TC_018 - Duplicate phone - Phone number already exists should display\", function () {",
                  "    if (statusCode === 409 && responseText.includes(\"phone\")) {",
                  "        pm.expect(responseText).to.satisfy(function (t) {",
                  "            return t.includes(\"already exists\") || t.includes(\"already\");",
                  "        });",
                  "    }",
                  "});",
                  "// TC_019 -- PHONE: Fake number",
                  "pm.test(\"TC_019 - Fake phone number - Invalid phone number should display\", function () {",
                  "    if (req.phoneNumber && /^0{7,}$/.test(req.phoneNumber)) {",
                  "        pm.expect(statusCode).to.equal(400);",
                  "        pm.expect(responseText).to.satisfy(function (t) {",
                  "            return t.includes(\"invalid phone\") || (t.includes(\"phone\") && t.includes(\"invalid\"));",
                  "        });",
                  "    }",
                  "});",
                  "// TC_020 -- PHONE: Special characters",
                  "pm.test(\"TC_020 - Special characters in phone - Invalid phone number should display\", function () {",
                  "    if (req.phoneNumber && /[^+\\d]/.test(req.phoneNumber)) {",
                  "        pm.expect(statusCode).to.equal(400);",
                  "        pm.expect(responseText).to.satisfy(function (t) {",
                  "            return t.includes(\"invalid phone\") || (t.includes(\"phone\") && t.includes(\"invalid\"));",
                  "        });",
                  "    }",
                  "});",
                  "// TC_021 -- PHONE: Global format",
                  "pm.test(\"TC_021 - Global phone format - should create user successfully\", function () {",
                  "    if (req.phoneNumber && req.phoneNumber.startsWith(\"+\") && req.phoneNumber.length >= 10) {",
                  "        if (statusCode === 200 || statusCode === 201) {",
                  "            pm.expect(responseText).to.include(\"success\");",
                  "        }",
                  "    }",
                  "});",
                  "// TC_022 -- PHONE: Only country code",
                  "pm.test(\"TC_022 - Only country code in phone - Invalid phone number should display\", function () {",
                  "    if (req.phoneNumber && /^\\+\\d{1,3}$/.test(req.phoneNumber)) {",
                  "        pm.expect(statusCode).to.equal(400);",
                  "        pm.expect(responseText).to.satisfy(function (t) {",
                  "            return t.includes(\"invalid phone\") || (t.includes(\"phone\") && t.includes(\"invalid\"));",
                  "        });",
                  "    }",
                  "});",
                  "// TC_023 -- ROLE: Empty",
                  "pm.test(\"TC_023 - Empty role - Role is required should display\", function () {",
                  "    if (req.role === \"\" || req.role === null) {",
                  "        pm.expect(statusCode).to.equal(400);",
                  "        pm.expect(responseText).to.satisfy(function (t) {",
                  "            return t.includes(\"role\") && t.includes(\"required\");",
                  "        });",
                  "    }",
                  "});",
                  "// TC_024 -- ROLE: Invalid role",
                  "pm.test(\"TC_024 - Invalid role - Invalid role selected should display\", function () {",
                  "    var validRoles = [\"professional measurer\", \"interior designer\", \"homeowner\"];",
                  "    if (req.role && validRoles.indexOf(req.role.toLowerCase()) === -1) {",
                  "        pm.expect(statusCode).to.equal(400);",
                  "        pm.expect(responseText).to.satisfy(function (t) {",
                  "            return t.includes(\"invalid role\") || (t.includes(\"role\") && t.includes(\"invalid\"));",
                  "        });",
                  "    }",
                  "});",
                  "// TC_025 -- ROLE: Multiple roles",
                  "pm.test(\"TC_025 - Multiple roles in one field - Only one role can be selected should display\", function () {",
                  "    if (req.role && req.role.toLowerCase().includes(\"designer\") && req.role.toLowerCase().includes(\"measurer\")) {",
                  "        pm.expect(statusCode).to.equal(400);",
                  "        pm.expect(responseText).to.satisfy(function (t) {",
                  "            return t.includes(\"one role\") || t.includes(\"only one\") || t.includes(\"invalid role\");",
                  "        });",
                  "    }",
                  "});",
                  "// TC_026 -- ROLE: Professional Measurer",
                  "pm.test(\"TC_026 - Valid role Professional Measurer - should create user successfully\", function () {",
                  "    if (req.role && req.role.toLowerCase() === \"professional measurer\") {",
                  "        if (statusCode === 200 || statusCode === 201) {",
                  "            pm.expect(responseText).to.include(\"success\");",
                  "        }",
                  "    }",
                  "});",
                  "// TC_027 -- ROLE: Interior Designer",
                  "pm.test(\"TC_027 - Valid role Interior Designer - should create user successfully\", function () {",
                  "    if (req.role && req.role.toLowerCase() === \"interior designer\") {",
                  "        if (statusCode === 200 || statusCode === 201) {",
                  "            pm.expect(responseText).to.include(\"success\");",
                  "        }",
                  "    }",
                  "});",
                  "// TC_028 -- ROLE: Homeowner",
                  "pm.test(\"TC_028 - Valid role Homeowner - should create user successfully\", function () {",
                  "    if (req.role && req.role.toLowerCase() === \"homeowner\") {",
                  "        if (statusCode === 200 || statusCode === 201) {",
                  "            pm.expect(responseText).to.include(\"success\");",
                  "        }",
                  "    }",
                  "});",
                  "// TC_029 -- LANGUAGE: Empty languageId",
                  "pm.test(\"TC_029 - Empty languageId - Language is required should display\", function () {",
                  "    if (req.languageId === \"\" || req.languageId === null) {",
                  "        pm.expect(statusCode).to.equal(400);",
                  "        pm.expect(responseText).to.satisfy(function (t) {",
                  "            return t.includes(\"language\") && t.includes(\"required\");",
                  "        });",
                  "    }",
                  "});",
                  "// TC_030 -- LANGUAGE: Invalid (fr)",
                  "pm.test(\"TC_030 - Invalid languageId fr - Unsupported language should display\", function () {",
                  "    var supportedLangs = [\"en\"];",
                  "    if (req.languageId && supportedLangs.indexOf(req.languageId.toLowerCase()) === -1) {",
                  "        pm.expect(statusCode).to.equal(400);",
                  "        pm.expect(responseText).to.satisfy(function (t) {",
                  "            return t.includes(\"unsupported\") || (t.includes(\"language\") && t.includes(\"invalid\"));",
                  "        });",
                  "    }",
                  "});",
                  "// TC_031 -- LANGUAGE: Valid (en)",
                  "pm.test(\"TC_031 - Valid languageId en - should create user successfully\", function () {",
                  "    if (req.languageId && req.languageId.toLowerCase() === \"en\") {",
                  "        if (statusCode === 200 || statusCode === 201) {",
                  "            pm.expect(responseText).to.include(\"success\");",
                  "        }",
                  "    }",
                  "});",
                  "// TC_032 -- E2E: All valid data",
                  "pm.test(\"TC_032 - All valid data E2E - User created successfully should display\", function () {",
                  "    if (req.fullName && req.email && req.phoneNumber && req.role && req.languageId &&",
                  "        (statusCode === 200 || statusCode === 201)) {",
                  "        pm.expect(responseText).to.include(\"success\");",
                  "    }",
                  "});",
                  "// TC_033 -- E2E: All invalid data",
                  "pm.test(\"TC_033 - All invalid data - all respective validation messages should display\", function () {",
                  "    if (statusCode === 400 && !req.fullName && !req.email && !req.phoneNumber) {",
                  "        pm.expect(responseText).to.satisfy(function (t) {",
                  "            return t.includes(\"required\") || t.includes(\"invalid\");",
                  "        });",
                  "    }",
                  "});",
                  "// TC_034 -- E2E: One field invalid",
                  "pm.test(\"TC_034 - One field invalid - only that field error should display\", function () {",
                  "    if (statusCode === 400) {",
                  "        var errorFields = [\"name\", \"email\", \"phone\", \"role\", \"language\"].filter(function (f) {",
                  "            return responseText.includes(f);",
                  "        });",
                  "        pm.expect(errorFields.length).to.be.at.least(1);",
                  "    }",
                  "});",
                  "// TC_035 -- E2E: Multiple invalid fields",
                  "pm.test(\"TC_035 - Multiple invalid fields - all invalid field messages should display\", function () {",
                  "    if (statusCode === 400 && (!req.email || !req.phoneNumber)) {",
                  "        pm.expect(responseText).to.satisfy(function (t) {",
                  "            return t.includes(\"invalid\") || t.includes(\"required\");",
                  "        });",
                  "    }",
                  "});",
                  "// TC_036 -- RESPONSE: Data matches request",
                  "pm.test(\"TC_036 - Response data should match request data\", function () {",
                  "    if (statusCode === 200 || statusCode === 201) {",
                  "        if (req.email) { pm.expect(res.data.email).to.eql(req.email); }",
                  "        if (req.phoneNumber) { pm.expect(res.data.phoneNumber).to.eql(req.phoneNumber); }",
                  "        if (req.role) { pm.expect(res.data.role).to.eql(req.role); }",
                  "    }",
                  "});",
                  "// TC_037 -- RESPONSE: 201 + success message",
                  "pm.test(\"TC_037 - 201 Created with correct success message\", function () {",
                  "    if (statusCode === 200 || statusCode === 201) {",
                  "        pm.expect(responseText).to.include(\"success\");",
                  "    }",
                  "});",
                  "// TC_038 -- RESPONSE: 400 + validation message",
                  "pm.test(\"TC_038 - 400 Bad Request with proper validation message for invalid input\", function () {",
                  "    if (statusCode === 400) {",
                  "        pm.expect(responseText).to.satisfy(function (t) {",
                  "            return t.includes(\"required\") || t.includes(\"invalid\") || t.includes(\"validation\");",
                  "        });",
                  "    }",
                  "});",
                  "// TC_039 -- RESPONSE: 409 + duplicate message",
                  "pm.test(\"TC_039 - 409 Conflict with duplicate message for duplicate email or phone\", function () {",
                  "    if (statusCode === 409) {",
                  "        pm.expect(responseText).to.satisfy(function (t) {",
                  "            return t.includes(\"already\") || t.includes(\"duplicate\") || t.includes(\"conflict\");",
                  "        });",
                  "    }",
                  "});",
                  "// TC_040 -- ERROR HANDLING: Null mandatory fields",
                  "pm.test(\"TC_040 - Null mandatory fields - proper validation message should display\", function () {",
                  "    var hasNull = Object.keys(req).some(function (k) { return req[k] === null; });",
                  "    if (hasNull && statusCode === 400) {",
                  "        pm.expect(responseText).to.satisfy(function (t) {",
                  "            return t.includes(\"required\") || t.includes(\"null\") || t.includes(\"invalid\");",
                  "        });",
                  "    }",
                  "});",
                  "// TC_041 -- ERROR HANDLING: Blank payload",
                  "pm.test(\"TC_041 - Blank payload - all required field messages should display\", function () {",
                  "    var isBlank = Object.keys(req).length === 0;",
                  "    if (isBlank && statusCode === 400) {",
                  "        pm.expect(responseText).to.include(\"required\");",
                  "    }",
                  "});",
                  "// TC_042 -- ERROR HANDLING: Missing one key",
                  "pm.test(\"TC_042 - Missing one key - that field validation message should display\", function () {",
                  "    if (statusCode === 400) {",
                  "        pm.expect(responseText).to.satisfy(function (t) {",
                  "            return t.includes(\"required\") || t.includes(\"missing\") || t.includes(\"invalid\");",
                  "        });",
                  "    }",
                  "});",
                  "// TC_043 -- ERROR HANDLING: Malformed JSON",
                  "pm.test(\"TC_043 - Malformed JSON - proper bad request response should display\", function () {",
                  "    if (statusCode === 400) {",
                  "        pm.expect(responseText).to.not.include(\"stack\");",
                  "        pm.expect(responseText).to.not.include(\"exception\");",
                  "    }",
                  "});",
                  "// TC_044 -- ERROR HANDLING: Wrong content-type",
                  "pm.test(\"TC_044 - Wrong content-type - proper validation or unsupported media type message\", function () {",
                  "    if (statusCode === 400 || statusCode === 415) {",
                  "        pm.expect(statusCode).to.be.oneOf([400, 415]);",
                  "    }",
                  "});",
                  "// TC_045 -- SECURITY: SQL injection in fullName",
                  "pm.test(\"TC_045 - SQL injection in fullName - invalid input detected or rejection\", function () {",
                  "    if (req.fullName && (req.fullName.includes(\"--\") || req.fullName.includes(\"1=1\"))) {",
                  "        pm.expect(statusCode).to.be.oneOf([400, 422]);",
                  "        pm.expect(responseText).to.not.include(\"sql\");",
                  "        pm.expect(responseText).to.not.include(\"syntax error\");",
                  "    }",
                  "});",
                  "// TC_046 -- SECURITY: XSS in fullName",
                  "pm.test(\"TC_046 - XSS in fullName - invalid input detected or safe rejection\", function () {",
                  "    if (req.fullName && req.fullName.includes(\"<script>\")) {",
                  "        pm.expect(statusCode).to.be.oneOf([400, 422]);",
                  "        pm.expect(pm.response.text()).to.not.include(\"<script>\");",
                  "    }",
                  "});",
                  "// TC_047 -- SECURITY: Script in email",
                  "pm.test(\"TC_047 - Script in email - proper validation or rejection message\", function () {",
                  "    if (req.email && req.email.includes(\"<script>\")) {",
                  "        pm.expect(statusCode).to.equal(400);",
                  "        pm.expect(pm.response.text()).to.not.include(\"<script>\");",
                  "        pm.expect(pm.response.text()).to.not.include(\"onerror=\");",
                  "    }",
                  "});",
                  "// TC_048 -- PERFORMANCE: Response time",
                  "pm.test(\"TC_048 - Response time should be below 500ms\", function () {",
                  "    pm.expect(pm.response.responseTime).to.be.below(500);",
                  "});",
                  "// TC_049 -- STABILITY: No server crash",
                  "pm.test(\"TC_049 - Server error handling - status should not be 500\", function () {",
                  "    pm.expect(statusCode).to.not.equal(500);",
                  "});",
                  "// TC_050 -- STABILITY: Extra fields in request",
                  "pm.test(\"TC_050 - Extra fields in payload - API should ignore or reject with proper message\", function () {",
                  "    var knownKeys = [\"fullName\", \"email\", \"phoneNumber\", \"role\", \"languageId\"];",
                  "    var extraKeys = Object.keys(req).filter(function (k) {",
                  "        return knownKeys.indexOf(k) === -1;",
                  "    });",
                  "    if (extraKeys.length > 0) {",
                  "        var passed = (statusCode === 200 || statusCode === 201) ||",
                  "            (statusCode === 400 && responseText.includes(\"invalid\"));",
                  "        pm.expect(passed).to.be.true;",
                  "    }",
                  "});",
                  "// TC_051 -- STABILITY: Case sensitivity in role",
                  "pm.test(\"TC_051 - Case sensitivity in role - validate according to rule and show proper message\", function () {",
                  "    if (req.role) {",
                  "        var validRoles = [\"professional measurer\", \"interior designer\", \"homeowner\"];",
                  "        var isValid = validRoles.indexOf(req.role.toLowerCase()) !== -1;",
                  "        if (!isValid) {",
                  "            pm.expect(statusCode).to.equal(400);",
                  "        }",
                  "    }",
                  "});",
                  "// TC_052 -- VALIDATION: Repeated submit same payload",
                  "pm.test(\"TC_052 - Repeated same payload - duplicate error should show for unique fields\", function () {",
                  "    if (statusCode === 409) {",
                  "        pm.expect(responseText).to.satisfy(function (t) {",
                  "            return t.includes(\"already\") || t.includes(\"duplicate\");",
                  "        });",
                  "    }",
